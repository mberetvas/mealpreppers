{
  "name": "mealprepper",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "eslint app server test scripts types utils eslint.config.mjs nuxt.config.ts tailwind.config.ts vitest.config.ts vitest.config.component.ts --fix",
    "generate": "nuxt generate",
    "lint": "eslint app server test scripts types utils eslint.config.mjs nuxt.config.ts tailwind.config.ts vitest.config.ts vitest.config.component.ts",
    "preview": "nuxt preview",
    "run:prod": "nuxt preview",
    "run:dev": "nuxt dev",
    "postinstall": "nuxt prepare && bun run rebuild:native",
    "rebuild:native": "npm rebuild better-sqlite3",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:component": "vitest --project component",
    "test:nuxt": "vitest --project nuxt",
    "test:ui-quality-remediation": "vitest run test/unit/primary-navigation-integrity.test.ts test/unit/design-token-compliance.test.ts test/unit/state-messaging-contract.test.ts test/unit/touch-ergonomics-contract.test.ts test/unit/visual-cost-budget.test.ts test/unit/list-image-loading-strategy.test.ts test/unit/component-vocabulary-contract.test.ts test/component/accessible-overlay-contract.test.ts test/component/list-image-loading-strategy.test.ts test/component/form-flow-status-surfaces.test.ts",
    "build:desktop": "bun scripts/build-desktop.mjs",
    "desktop:dev": "tauri dev",
    "desktop:dev:sidecar": "bun scripts/tauri-dev-sidecar.mjs",
    "desktop:run:dev": "bun run desktop:dev:sidecar",
    "desktop:run:prod": "bun scripts/run-desktop-built.mjs",
    "desktop:build": "bun run build:desktop && tauri build",
    "desktop:build:console": "bun run build:desktop && tauri build -- --features console",
    "desktop:pack": "bun run desktop:build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/material-symbols-outlined": "^5.2.8",
    "@langchain/core": "^1.1.48",
    "@langchain/openrouter": "^0.3.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@tauri-apps/api": "^2.9.1",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "nuxt": "^4.4.4",
    "playwright": "^1.60.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "better-sqlite3",
    "unrs-resolver"
  ],
  "devDependencies": {
    "@tauri-apps/cli": "2",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "magic-string": "^0.30.21",
    "vitest": "^4.1.5"
  }
}
