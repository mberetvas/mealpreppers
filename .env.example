# Copy to `.env` and fill in values. Never commit real secrets.

# --- Local data paths (optional; defaults to repo `.data/` in dev) ---
# Root for SQLite DB and recipe-images/. Tauri sidecar sets this automatically.
# MEALPREPPER_DATA_DIR=./.data
# Override SQLite file path (defaults to ${MEALPREPPER_DATA_DIR}/mealprepper.db).
# DATABASE_PATH=./.data/mealprepper.db
# Override recipe image directory (defaults to ${MEALPREPPER_DATA_DIR}/recipe-images).
# RECIPE_IMAGES_DIR=./.data/recipe-images

# --- Desktop sidecar (loop B / packaged app) ---
# Per-launch token injected by Tauri; Axum middleware enforces X-Desktop-Token (except /health).
# For local sidecar-only dev without Tauri, set a fixed value matching your test client.
# DESKTOP_TOKEN=<dev-only-secret>

# Set to '1' to emit startup timing milestones to the log (dev / profiling).
# MEALPREPPER_STARTUP_TIMING=1

# --- Server logging (optional; see README “Server logging”) ---
# Minimum severity: debug | info | warn | error
# Defaults: development → debug, production → info (when unset or invalid).
# LOG_LEVEL=debug

# Only `true` enables newline-delimited JSON logs on stdout.
# Any other value keeps Consola's default pretty output.
# LOG_JSON=false

# --- Shopping list AI polish via OpenRouter (optional until consolidate is used) ---
# In Tauri builds, prefer Settings → keychain; this env var is for `bun run dev` / loop A.
# OPENROUTER_API_KEY=<your-openrouter-api-key>
# OPENROUTER_SHOPPING_LIST_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_APP_URL=https://your-mealprepper-origin
# OPENROUTER_APP_TITLE=Mealprepper
# Abort budget for polish invoke (ms). Increase for large lists or slower models.
# OPENROUTER_SHOPPING_LIST_TIMEOUT_MS=60000

# --- LangSmith (optional; dev/staging prompt debugging) ---
# LANGSMITH_API_KEY=<your-langsmith-api-key>
# LANGSMITH_TRACING=true
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=mealprepper-shopping-list

# --- Runtime environment (usually set by the runtime or host) ---
# `production` changes logger defaults.
# NODE_ENV=development
